COMPOSE_PROJECT_NAME=retail-analytics

POSTGRES_DB=retail_analytics
POSTGRES_USER=retail
POSTGRES_PASSWORD=retail
POSTGRES_PORT=15438

REDIS_PORT=16379

BACKEND_PORT=18000
ML_API_PORT=18001
FRONTEND_PORT=13000
SUPERSET_PORT=18088

APP_ENV=local
APP_LOG_LEVEL=INFO

BACKEND_APP_NAME=retail-analytics-backend
ML_API_APP_NAME=retail-analytics-ml-api

POSTGRES_DSN=postgresql+psycopg://retail:retail@postgres:5432/retail_analytics
ALEMBIC_DATABASE_URL=postgresql+psycopg://retail:retail@postgres:5432/retail_analytics
REDIS_URL=redis://redis:6379/0
BI_READONLY_USER=bi_readonly
BI_READONLY_PASSWORD=bi_readonly
BI_POSTGRES_DSN=postgresql+psycopg2://bi_readonly:bi_readonly@postgres:5432/retail_analytics
SUPERSET_METADATA_DB=superset_metadata

NEXT_PUBLIC_BACKEND_URL=http://localhost:18000
NEXT_PUBLIC_ML_API_URL=http://localhost:18001

SUPERSET_DATABASE_URI=postgresql+psycopg2://retail:retail@postgres:5432/superset_metadata
SUPERSET_ANALYTICS_DATABASE_URI=postgresql+psycopg2://bi_readonly:bi_readonly@postgres:5432/retail_analytics
SUPERSET_SECRET_KEY=replace-me-for-shared-environments
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_FIRSTNAME=Superset
SUPERSET_ADMIN_LASTNAME=Admin
SUPERSET_ADMIN_EMAIL=admin@example.com
SUPERSET_ADMIN_PASSWORD=admin
